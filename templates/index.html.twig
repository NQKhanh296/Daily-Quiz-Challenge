{% extends 'base.html.twig' %}

{% block body %}
<div class="container">
    <h1>Denní kvízová výzva</h1>

    <div id="authScreen" class="screen">
        <h2>Vítej v kvízu</h2>
        <p class="subtitle">Získej nový kód nebo se vrať ke svému účtu.</p>

        <div id="wordDisplay" class="word-box">
            <span class="word">...</span>
            <span class="word">...</span>
            <span class="word">...</span>
        </div>

        <button onclick="generateNewWords()" id="genBtn">Vygenerovat jiná slova</button>

        <div class="divider">nebo zadej svůj kód</div>

        <input type="password" id="manualWords" class="input-field" placeholder="slovo1 slovo2 slovo3">

        <button class="primary" onclick="authenticateUser()">Vstoupit do kvízu</button>

        <p class="small">
            Slova slouží jako váš unikátní login.
        </p>
    </div>

    <div id="startScreen" class="screen hidden">
        <h2>Dnešní výzva</h2>
        <p id="todayTopic" class="text-center">Téma: <span>Načítání...</span></p>

        <div class="buttons">
            <button onclick="startQuiz(1)">Lehká</button>
            <button onclick="startQuiz(2)">Střední</button>
            <button onclick="startQuiz(3)">Těžká</button>
        </div>

        <button class="secondary" onclick="showLeaderboard()">Zobrazit žebříček</button>
    </div>

    <div id="quizScreen" class="screen hidden">
        <div class="header">
            <span>Otázka <span id="questionNum">1</span>/3</span>
            <span><span id="timer">0</span>s</span>
        </div>

        <h2 id="questionText">Načítám otázku</h2>

        <div id="answers"></div>

        <div class="controls">
            <button id="nextBtn" class="hidden" onclick="handleNextStep()">Další otázka</button>
        </div>

        <p class="text-center">Skóre: <span id="score">0</span></p>
    </div>

    <div id="resultScreen" class="screen hidden">
        <h2>Hotovo!</h2>
        <p class="big text-center">Tvoje skóre: <span id="finalScore">0</span></p>
        <p class="text-center">Čas: <span id="finalTime">0</span>s</p>
        <button class="primary" onclick="showLeaderboard()">Zobrazit žebříček</button>
    </div>

    <div id="leaderboardScreen" class="screen hidden">
        <h2>Žebříček TOP 10</h2>

        <div class="current-user-stats text-center">
            <strong>Poslední hra:</strong> <span id="playerCurrentAttempt">0</span> bodů (<span id="playerCurrentTime">0</span>s)<br>
            <strong style="margin-top: 5px; display: inline-block;">Celkově:</strong> <span id="currentUserScore">0</span> bodů | <strong>Pozice:</strong> <span id="currentUserRank">?</span>.
        </div>

        <ul id="leaderboardList" class="leaderboard-list"></ul>

        <div class="divider">nastavení účtu</div>

        <button class="secondary" onclick="toggleUsernameForm()">Změnit jméno</button>

        <div id="changeUsernameForm" class="hidden">
            <input type="text" id="newUsernameInput" class="input-field" placeholder="Nové uživatelské jméno">
            <button class="primary" onclick="changeUsername()">Uložit jméno</button>
        </div>

        <div class="buttons mt-10">
            <button class="primary" onclick="showScreen('startScreen')">Zpět do menu</button>
            <button onclick="logout()">Odhlásit se</button>
        </div>
    </div>
</div>
{% endblock %}